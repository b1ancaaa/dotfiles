call plug#begin('~/.vim/plugged')
Plug 'vim-airline/vim-airline'
Plug 'vim-airline/vim-airline-themes' " 添加这一行
Plug 'tpope/vim-commentary'
Plug 'kshenoy/vim-signature'
Plug 'mhinz/vim-startify'
Plug 'christoomey/vim-tmux-navigator'
Plug 'catppuccin/vim', { 'as': 'catppuccin' }
call plug#end()
" 关闭对vi的兼容
set nocompatible
" 设置backspace键功能
set backspace=eol,start,indent
" 显示行号
set number
set relativenumber
" 高亮显示当前行
set cursorline
" 让一行的内容不换行
set nowrap
" 距窗口边缘还有多少行时滚动窗口
set scrolloff=8

" 显示标尺,提示一行代码不要超过80个字
set ruler
set colorcolumn=80
" 隐藏底部的状态栏 (0: 永不显示; 1: 多于一个窗口时显示; 2: 总是显示)
set laststatus=0
" 缩短消息显示的长度，减少这类信息的出现频率
set shortmess+=F
" tab设为4个空格
set tabstop=4
set shiftwidth=4
set softtabstop=4
set expandtab
set smarttab
" 新一行与上一行的缩进一致
set autoindent
" 显示括号匹配
set showmatch
" 高亮查找匹配
set hlsearch
" 增量式搜索
set incsearch
" 不区分大小写,除非含有大写字母
set ignorecase
set smartcase
" 开启语法高亮
syntax on
" 代码颜色主题
set termguicolors
colorscheme catppuccin_mocha
let g:airline_theme = 'catppuccin_mocha'
" 在右下角显示部分命令
set showcmd
" 命令可以用tab补全,并设置匹配规则
set wildmenu
set wildmode=list:longest,full
" 显示tab和行尾多余的空格
set nolist
set listchars=tab:>·,trail:·
" 允许隐藏未保存的buffer
set hidden
" 设置分屏时的位置
set splitright
set splitbelow
" 检测文件类型
filetype on
" 文件编码
set encoding=utf-8
set fileencodings=ucs-bom,utf-8,utf-16,gbk,big5,gb18030,latin1
" 没有保存或文件只读时弹出确认
set confirm
" 记录历史记录的条数
set history=1000
set undolevels=1000
" 禁用自动备份
set nobackup
set nowritebackup
set noswapfile
" 关闭错误提示音
set vb t_vb=
" 打通系统剪贴板
set clipboard=unnamed,unnamedplus

" shortcuts
inoremap jk <Esc>

" 开启持久化撤销（undo），即使关闭再打开文件，也能撤销之前的更改
set undofile

" " undo目录
if !isdirectory(expand("~/.cache/vim/undo"))
    call mkdir(expand("~/.cache/vim/undo"), "p")
endif
set undodir=~/.cache/vim/undo
" 剪贴板 gvim的功能
set clipboard=unnamedplus

" 接管鼠标事件
set mouse=a

inoremap jk <Esc>
